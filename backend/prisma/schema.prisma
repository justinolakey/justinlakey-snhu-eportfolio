// Prisma schema for the New Home Communities application.
// Defines the PostgreSQL database models and enums.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// A new-home community listing with location, builder info, and
// min/max ranges for price, square footage, lot size, bedrooms, and bathrooms.
model Community {
  id             Int             @id @default(autoincrement())
  name           String
  builder        String
  description    String?
  address        String
  city           String
  state          String
  zipCode        String
  latitude       Float           // GPS coordinates for map placement
  longitude      Float
  website        String?
  priceMin       Int             // Lowest starting price across available floor plans
  priceMax       Int             // Highest starting price across available floor plans
  sqftMin        Int             // Smallest home square footage offered
  sqftMax        Int             // Largest home square footage offered
  lotSizeSqftMin Int             // Smallest lot size in square feet
  lotSizeSqftMax Int             // Largest lot size in square feet
  bedroomsMin    Int
  bedroomsMax    Int
  bathroomsMin   Float           // Float to support half-baths (e.g. 2.5)
  bathroomsMax   Float
  status         CommunityStatus @default(AVAILABLE)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

// Availability status for a community
enum CommunityStatus {
  AVAILABLE
  SOLD_OUT
  COMING_SOON
}

// Registered user account. New users default to PENDING status
// and must be approved by an admin before they can add communities.
model User {
  id        Int        @id @default(autoincrement())
  email     String     @unique
  password  String     // bcrypt-hashed password
  role      UserRole   @default(USER)
  status    UserStatus @default(PENDING)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

enum UserRole {
  USER
  ADMIN
}

// Approval workflow: PENDING -> APPROVED or REJECTED by an admin
enum UserStatus {
  PENDING
  APPROVED
  REJECTED
}
