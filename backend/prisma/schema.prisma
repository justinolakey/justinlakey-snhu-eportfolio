generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Community {
  id             Int             @id @default(autoincrement())
  name           String
  builder        String
  description    String?
  address        String
  city           String
  state          String
  zipCode        String
  latitude       Float
  longitude      Float
  website        String?
  priceMin       Int
  priceMax       Int
  sqftMin        Int
  sqftMax        Int
  lotSizeSqftMin Int
  lotSizeSqftMax Int
  bedroomsMin    Int
  bedroomsMax    Int
  bathroomsMin   Float
  bathroomsMax   Float
  status         CommunityStatus @default(AVAILABLE)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

enum CommunityStatus {
  AVAILABLE
  SOLD_OUT
  COMING_SOON
}

model User {
  id        Int        @id @default(autoincrement())
  email     String     @unique
  password  String
  role      UserRole   @default(USER)
  status    UserStatus @default(PENDING)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
}
